          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">📍</div>
          <div class="contact-item-text">
            <h4>Localização</h4>
            <p>Salvador, Bahia — Brasil</p>
          </div>
        </div>
      </div>
    </div>
    <div class="reveal">
      <div class="contact-form">
        <div class="form-row">
          <div class="form-group">
