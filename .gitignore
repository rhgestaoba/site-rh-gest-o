            <input type="text" placeholder="Seu nome completo">
          </div>
          <div class="form-group">
            <label>Telefone</label>
            <input type="text" placeholder="(00) 00000-0000">
          </div>
        </div>
        <div class="form-group">
          <label>E-mail</label>
          <input type="email" placeholder="seu@email.com">
        </div>
        <div class="form-group">
          <label>Você é</label>
          <select>
            <option value="">Selecione uma opção</option>
            <option>Candidato em busca de oportunidade</option>
            <option>Empresa buscando talentos</option>
            <option>RH parceiro</option>
            <option>Outro</option>
          </select>
        </div>
        <div class="form-group">
          <label>Mensagem</label>
          <textarea rows="4" placeholder="Como podemos ajudar?"></textarea>
        </div>
        <button class="form-submit" onclick="alert('Mensagem enviada! Entraremos em contato em breve.')">
          Enviar mensagem
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l10-5-4 5 4 5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </button>
